{
  "name": "crispy-recall",
  "version": "0.2.1",
  "description": "Local session transcript memory for Claude Code and Codex — search past sessions with FTS5 + semantic vectors.",
  "license": "MIT",
  "author": "Sylvester Wong",
  "homepage": "https://github.com/TheSylvester/crispy-recall#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSylvester/crispy-recall.git"
  },
  "keywords": [
    "claude-code",
    "codex",
    "transcript",
    "memory",
    "recall",
    "fts5",
    "embeddings",
    "semantic-search",
    "sqlite"
  ],
  "bin": {
    "recall": "./dist/recall.js",
    "recall-stop-hook": "./dist/stop-hook.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "THIRD-PARTY-LICENSES"
  ],
  "engines": {
    "node": ">=22.16.0 <23 || >=24.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build && rm -f dist/better_sqlite3.node"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.114",
    "@clack/prompts": "^0.7.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "extract-zip": "^2.0.1",
    "glob": "^10.4.5",
    "node-sqlite3-wasm": "^0.8.53",
    "picocolors": "^1.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
